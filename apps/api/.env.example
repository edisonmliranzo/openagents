# App
PORT=3001
# Optional alias (takes precedence over PORT)
API_PORT=3001
# Used by local CORS fallback if FRONTEND_URLS is not set
WEB_PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/openagents"

# Redis
REDIS_URL="redis://localhost:6379"
# Approval continuation mode:
# - inline (default): API executes approved tools immediately and continues conversation
# - queue: API enqueues continuation job for worker
APPROVAL_CONTINUATION_MODE="inline"
# Optional shared token for worker -> API internal continuation endpoint.
# If set, worker requests must include header: x-approval-worker-token.
APPROVAL_WORKER_TOKEN=""
# Worker-only settings (used by @openagents/worker when queue mode is enabled):
APPROVAL_CONTINUATION_API_URL="http://localhost:3001"
APPROVAL_CONTINUATION_HTTP_TIMEOUT_MS="15000"

# JWT
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-in-production-use-a-different-long-string"
JWT_REFRESH_EXPIRES_IN="7d"
AUTH_BCRYPT_ROUNDS="12"
AUTH_MAX_REFRESH_TOKENS="10"
AUTH_RATE_WINDOW_MS="900000"
AUTH_MAX_FAILED_ATTEMPTS_PER_IDENTITY="10"
AUTH_MAX_FAILED_ATTEMPTS_PER_IP="30"
AUTH_LOCKOUT_MS="1800000"
# Private creator bootstrap (never commit your real email):
CREATOR_EMAIL=""
# Optional comma-separated list (owner bootstrap on login/register)
CREATOR_EMAILS=""

# LLM Providers
ANTHROPIC_API_KEY="sk-ant-..."
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="AIza..."
MINIMAX_API_KEY=""
DEFAULT_LLM_PROVIDER="anthropic"
ALLOW_CUSTOM_LLM_BASE_URLS="false"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_ALLOWED_HOSTS="localhost,127.0.0.1,::1,host.docker.internal"
WEB_SEARCH_PROVIDER="auto"
BRAVE_SEARCH_API_KEY=""
SEARXNG_BASE_URL=""
SEARXNG_API_KEY=""
# Computer-use runtime
# auto: prefer Playwright, fallback to HTTP static parser if unavailable
COMPUTER_USE_PROVIDER="auto"
COMPUTER_USE_PLAYWRIGHT_BROWSER="chromium"
COMPUTER_USE_PLAYWRIGHT_HEADLESS="true"
COMPUTER_USE_MAX_SCREENSHOT_BYTES="120000"
# If true, HTTP sessions can auto-upgrade to Playwright for likely JS-rendered pages.
COMPUTER_USE_HTTP_RENDER_FALLBACK="true"
COMPUTER_USE_PLAYWRIGHT_WAIT_UNTIL="domcontentloaded"
COMPUTER_USE_PLAYWRIGHT_NAV_TIMEOUT_MS="25000"
COMPUTER_USE_PLAYWRIGHT_NETWORK_IDLE_TIMEOUT_MS="1500"
COMPUTER_USE_PLAYWRIGHT_WAIT_FOR_SELECTOR=""
COMPUTER_USE_PLAYWRIGHT_WAIT_FOR_SELECTOR_TIMEOUT_MS="3500"
COMPUTER_USE_PLAYWRIGHT_SELECTOR_RETRY_COUNT="3"
COMPUTER_USE_PLAYWRIGHT_SELECTOR_RETRY_DELAY_MS="350"
COMPUTER_USE_PLAYWRIGHT_SETTLE_TIMEOUT_MS="4500"
COMPUTER_USE_PLAYWRIGHT_SETTLE_STABLE_MS="700"
COMPUTER_USE_PLAYWRIGHT_SETTLE_POLL_MS="140"

# MANUS_LITE preset (cost-aware routing + stronger tool loop defaults)
MANUS_LITE="false"
# If true, applies MANUS_LITE routing even when a non-default user provider/model is saved.
MANUS_LITE_FORCE_ROUTING="false"
MANUS_LITE_PROVIDER="ollama"
MANUS_LITE_MODEL="phi3"
MANUS_LITE_MAX_TOOL_ROUNDS="10"
MANUS_LITE_TOOL_RETRY_ATTEMPTS="2"
MANUS_LITE_TOOL_RETRY_BASE_DELAY_MS="350"
MANUS_LITE_NANOBOT_MAX_LOOP_STEPS="10"
AGENT_MAX_TOOL_ROUNDS="6"
AGENT_TOOL_RETRY_ATTEMPTS="1"
AGENT_TOOL_RETRY_BASE_DELAY_MS="500"

# Bybit demo trading tools (optional)
BYBIT_BASE_URL="https://api-demo.bybit.com"
BYBIT_PUBLIC_BASE_URL="https://api.bybit.com"
BYBIT_API_KEY=""
BYBIT_API_SECRET=""
BYBIT_DEMO_ONLY="true"
BYBIT_RECV_WINDOW="5000"

# Nanobot runtime
NANOBOT_ENABLED="false"
NANOBOT_MAX_LOOP_STEPS="8"
NANOBOT_SHADOW_MODE="false"
NANOBOT_RUNTIME_LABEL="nanobot"

# Encryption (for storing provider OAuth tokens)
ENCRYPTION_KEY="32-char-hex-key-here"

# Google OAuth (for Gmail + Calendar)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3001/api/v1/tools/google/callback"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"
# Optional: comma-separated allowed frontend origins
# FRONTEND_URLS="http://localhost:3000,http://127.0.0.1:3000,http://192.168.1.50:3000"

# WhatsApp channel (Twilio)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
WHATSAPP_DEFAULT_USER_ID=""
WHATSAPP_PAIR_COMMAND="link"
# Optional token required as webhook query parameter: /api/v1/channels/whatsapp/webhook?token=...
WHATSAPP_WEBHOOK_TOKEN=""

# Optional: filesystem memory root (default: <repo>/data/memory)
# MEMORY_FILES_ROOT="C:/path/to/memory-root"
