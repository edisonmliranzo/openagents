generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// SQLite-compatible schema (no enums, Json→String, arrays→String)

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  avatarUrl    String?
  passwordHash String
  role         String   @default("member")  // owner | admin | member
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conversations  Conversation[]
  connectedTools ConnectedTool[]
  approvals      Approval[]
  memories       Memory[]
  memoryEvents   MemoryEvent[]
  memoryFacts    MemoryFact[]
  memoryConflicts MemoryConflict[]
  connectorHealth ConnectorHealth[]
  skillRegistryEntries SkillRegistryEntry[]
  extractionJobs ExtractionJob[]
  ciIncidents    CiIncident[]
  refreshTokens  RefreshToken[]
  settings       UserSettings?
  domains        UserDomain[]
  deviceInstalls DeviceInstall[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  cronJobs       CronJob[]
  llmApiKeys       LlmApiKey[]
  llmKeyFallbacks  LlmApiKeyFallback[]
  whatsAppDevices  WhatsAppDevice[]
  whatsAppPairings WhatsAppPairing[]
  telegramChats    TelegramChat[]
  telegramPairings TelegramPairing[]
  slackWorkspaces  SlackWorkspace[]
  slackPairings    SlackPairing[]
  discordServers   DiscordServer[]
  discordPairings  DiscordPairing[]
  subagentRuns     SubagentRun[]
  delegationEdges  DelegationEdge[]
  webhooks         Webhook[]
  webhookDeliveries WebhookDelivery[]
  triggers         Trigger[]
  triggerEvents    TriggerEvent[]
  metricLogs       MetricLog[]
  budgetLimits     BudgetLimit[]
  conversationSummaries ConversationSummary[]
  conversationHighlights ConversationHighlight[]
  actionItems      ActionItem[]
  agentPresets     AgentPreset[]
  artifacts        Artifact[]
  artifactTemplates ArtifactTemplate[]
  ownedWorkspaces  Workspace[] @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  workspaceMemoryEntries WorkspaceMemoryEntry[]
  packs            Pack[]
  packInstalls     PackInstall[]
  anomalies        Anomaly[]
  anomalyAlerts    AnomalyAlert[]
  anomalyConfigs   AnomalyConfig[]
  agentVersions    AgentVersion[]
}

model Anomaly {
  id              String   @id @default(cuid())
  userId          String
  type            String
  severity        String
  status          String   @default("detected")
  description     String
  metrics         Json
  recommendations Json
  detectedAt      DateTime @default(now())
  resolvedAt      DateTime?
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([detectedAt])
}

model AnomalyAlert {
  id         String  @id @default(cuid())
  userId     String
  anomalyId  String?
  channel    String
  target     String
  enabled    Boolean @default(true)
  threshold  Float   @default(1.0)
  createdAt  DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model AnomalyConfig {
  userId             String   @id
  enabled            Boolean  @default(true)
  sensitivity        String   @default("medium")
  alertChannels      Json     @default("[]")
  ignoredPatterns    Json     @default("[]")
  baselineWindowDays Int      @default(7)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Conversation {
  id            String    @id @default(cuid())
  userId        String
  title         String?
  sessionLabel  String?
  thinkingLevel String?
  verboseLevel  String?
  reasoningLevel String?
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  approvals Approval[]
  agentRuns AgentRun[]
  subagentRuns SubagentRun[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user | agent | tool | system
  content        String
  status         String   @default("done")  // pending | streaming | done | error
  toolCallJson   String?  // JSON string
  toolResultJson String?  // JSON string
  metadata       String?  // JSON string
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  approval     Approval?
}

model AgentRun {
  id             String    @id @default(cuid())
  conversationId String
  status         String    @default("idle")  // idle | thinking | running_tool | waiting_approval | done | error
  startedAt      DateTime  @default(now())
  finishedAt     DateTime?
  error          String?
  metadata       String?   // JSON string

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model SubagentRun {
  id             String    @id @default(cuid())
  userId         String
  conversationId String?
  parentRunId    String?
  role           String    // planner | researcher | builder | operator | reviewer
  label          String
  objective      String
  input          String    @default("{}") // JSON string
  output         String?
  status         String    @default("queued") // queued | running | done | error
  startedAt      DateTime?
  finishedAt     DateTime?
  error          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation  Conversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  outgoingEdges DelegationEdge[] @relation("SubagentRunOutgoing")
  incomingEdges DelegationEdge[] @relation("SubagentRunIncoming")

  @@index([userId, createdAt])
  @@index([conversationId])
  @@index([parentRunId])
  @@map("subagent_run")
}

model DelegationEdge {
  id        String   @id @default(cuid())
  userId    String
  fromRunId String
  toRunId   String
  intent    String
  status    String   @default("delegated") // delegated | accepted | completed | failed
  metadata  String?  // JSON string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromRun SubagentRun @relation("SubagentRunOutgoing", fields: [fromRunId], references: [id], onDelete: Cascade)
  toRun   SubagentRun @relation("SubagentRunIncoming", fields: [toRunId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([fromRunId])
  @@index([toRunId])
  @@map("delegation_edge")
}

model Tool {
  id               String  @id @default(cuid())
  name             String  @unique
  displayName      String
  description      String
  category         String  // email | calendar | web | notes | custom
  requiresApproval Boolean @default(true)
  inputSchema      String  // JSON string

  connectedTools ConnectedTool[]
}

model ConnectedTool {
  id              String   @id @default(cuid())
  userId          String
  toolId          String
  status          String   @default("connected")  // available | connected | error
  encryptedTokens String?
  connectedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tool Tool @relation(fields: [toolId], references: [id])

  @@unique([userId, toolId])
}

model Approval {
  id             String    @id @default(cuid())
  conversationId String
  messageId      String    @unique
  userId         String
  toolName       String
  toolInput      String    // JSON string
  status         String    @default("pending")  // pending | approved | denied
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])
}

model Memory {
  id        String   @id @default(cuid())
  userId    String
  type      String   // fact | preference | summary
  content   String
  tags      String   @default("[]")  // JSON array string
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MemoryEvent {
  id          String   @id @default(cuid())
  userId      String
  kind        String   // conversation | workflow | incident | extraction | note
  summary     String
  payload     String?  // JSON string
  sourceRef   String?
  tags        String   @default("[]") // JSON array string
  piiRedacted Boolean  @default(true)
  confidence  Float    @default(0.8)
  freshUntil  DateTime?
  conflictGroup String?
  reinforcedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, kind, updatedAt])
  @@index([userId, confidence, updatedAt])
  @@index([userId, freshUntil])
}

model MemoryFact {
  id         String   @id @default(cuid())
  userId     String
  entity     String
  key        String
  value      String
  sourceRef  String?
  confidence Float    @default(0.8)
  freshUntil DateTime?
  conflictGroup String?
  reinforcedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entity, key])
  @@index([userId, updatedAt])
  @@index([userId, confidence, updatedAt])
  @@index([userId, freshUntil])
}

model MemoryConflict {
  id                String   @id @default(cuid())
  userId            String
  entity            String
  key               String
  existingValue     String
  incomingValue     String
  existingSourceRef String?
  incomingSourceRef String?
  status            String   @default("open") // open | resolved | ignored
  severity          String   @default("medium") // low | medium | high
  confidenceDelta   Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  resolvedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, updatedAt])
  @@index([userId, entity, key, createdAt])
}

model ConnectorHealth {
  id            String   @id @default(cuid())
  userId        String
  connectorId   String
  status        String   @default("connected") // connected | degraded | down
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  lastError     String?
  tokenExpiresAt DateTime?
  p95LatencyMs  Int?
  rateLimitHits Int      @default(0)
  failureStreak Int      @default(0)
  metadata      String?  // JSON string
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, connectorId])
  @@index([userId, status, updatedAt])
}

model SkillRegistryEntry {
  id               String   @id @default(cuid())
  userId           String
  skillId          String
  title            String
  description      String
  installedVersion String?
  pinnedAgents     String   @default("{}") // JSON map { agentId: version }
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions SkillRegistryVersion[]

  @@unique([userId, skillId])
  @@index([userId, updatedAt])
}

model SkillRegistryVersion {
  id                String   @id @default(cuid())
  entryId           String
  version           String
  changelog         String
  manifestJson      String   // JSON string
  compatibilityJson String?  // JSON string
  signature         String
  createdAt         DateTime @default(now())
  publishedAt       DateTime @default(now())

  entry SkillRegistryEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([entryId, version])
  @@index([entryId, publishedAt])
}

model ExtractionJob {
  id               String   @id @default(cuid())
  userId           String
  sourceKind       String   // pdf | email | web | text
  sourceUri        String
  schemaVersion    String
  schemaJson       String   // JSON string
  optionsJson      String?  // JSON string
  status           String   @default("queued") // queued | processing | completed | failed | needs_review
  outputJson       String?  // JSON string
  confidence       Float    @default(0)
  reviewerStatus   String?  // pending | approved | rejected
  failureReason    String?
  validationIssues String   @default("[]") // JSON array string
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, updatedAt])
}

model CiIncident {
  id                 String   @id @default(cuid())
  userId             String
  provider           String
  repo               String
  branch             String?
  pipelineId         String?
  jobName            String?
  commitSha          String?
  logExcerpt         String?
  artifactUrls       String   @default("[]") // JSON array string
  failureClass       String   @default("unknown")
  status             String   @default("queued") // queued | analyzing | auto_retrying | patch_proposed | resolved | failed
  summary            String?
  suggestedFix       String?
  prUrl              String?
  retryCount         Int      @default(0)
  failureFingerprint String?
  metadata           String?  // JSON string
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([repo, commitSha])
  @@index([status, updatedAt])
}

model UserSettings {
  id                 String   @id @default(cuid())
  userId             String   @unique
  preferredProvider  String   @default("anthropic")
  preferredModel     String   @default("claude-sonnet-4-6")
  customSystemPrompt String?
  lastActiveConversationId String?
  beginnerMode       Boolean  @default(true)
  onboardingCompletedAt DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserDomain {
  id                String   @id @default(cuid())
  userId            String
  domain            String
  status            String   @default("pending") // pending | active | error
  provider          String   @default("manual")  // manual | cloudflare | caddy | nginx
  targetHost        String?  // public IP/host and port, e.g. 203.0.113.10:4300
  proxyInstructions String?  // free-form notes
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, domain])
  @@index([userId, createdAt])
}

model DeviceInstall {
  id         String   @id @default(cuid())
  userId     String
  deviceHash String
  userAgent  String?
  ipAddress  String?
  firstSeenAt DateTime @default(now())
  lastSeenAt DateTime @default(now())
  loginCount Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceHash])
  @@index([lastSeenAt])
  @@index([userId, lastSeenAt])
}

model AuditLog {
  id          String      @id @default(cuid())
  userId      String
  category    String
  action      String
  resource    String
  severity    String
  description String
  ipAddress   String?
  userAgent   String?
  metadata    String?
  timestamp   DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([category])
  @@index([severity])
  @@index([timestamp])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")  // info | warning | success | error
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CronJob {
  id             String   @id @default(cuid())
  userId         String
  name           String
  description    String?
  enabled        Boolean  @default(true)
  scheduleKind   String   @default("every") // every | at | cron
  scheduleValue  String
  sessionTarget  String   @default("main") // main | isolated
  payloadKind    String   @default("systemEvent") // systemEvent | agentTurn
  payloadText    String
  deliveryMode   String   @default("none") // none | announce | webhook
  deliveryTarget String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs CronRun[]
}

model CronRun {
  id        String   @id @default(cuid())
  cronJobId String
  status    String   @default("ok") // ok | error | skipped
  summary   String?
  error     String?
  durationMs Int?
  createdAt DateTime @default(now())

  job CronJob @relation(fields: [cronJobId], references: [id], onDelete: Cascade)
}

model LlmApiKey {
  id        String   @id @default(cuid())
  userId    String
  provider  String   // 'anthropic' | 'openai' | 'ollama'
  apiKey    String?  // null for Ollama
  baseUrl   String?  // for Ollama: 'http://localhost:11434'
  loginEmail String?
  loginPassword String?
  subscriptionPlan String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model WhatsAppDevice {
  id                 String   @id @default(cuid())
  userId             String
  phone              String   @unique
  label              String?
  linkedAt           DateTime @default(now())
  lastSeenAt         DateTime?
  lastConversationId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model WhatsAppPairing {
  id                 String   @id @default(cuid())
  userId             String
  code               String   @unique
  command            String
  status             String   @default("pending") // pending | linked | expired | canceled
  phone              String?
  expiresAt          DateTime
  linkedAt           DateTime?
  consumedMessageSid String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

// ─── LLM API Key Fallbacks (for multi-key rotation / failover) ────────────────

model LlmApiKeyFallback {
  id        String    @id @default(cuid())
  userId    String
  provider  String    // 'anthropic' | 'openai' | 'google' | 'minimax'
  apiKey    String
  label     String?   // e.g. "Backup 1", "Team key"
  priority  Int       @default(10) // lower = tried first (primary LlmApiKey is 0)
  isActive  Boolean   @default(true)
  failedAt  DateTime?
  failCount Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider, priority])
}

// ─── Telegram ─────────────────────────────────────────────────────────────────

model TelegramChat {
  id                 String    @id @default(cuid())
  userId             String
  chatId             String    @unique
  label              String?
  linkedAt           DateTime  @default(now())
  lastSeenAt         DateTime?
  lastConversationId String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model TelegramPairing {
  id        String    @id @default(cuid())
  userId    String
  code      String    @unique
  command   String
  status    String    @default("pending") // pending | linked | expired | canceled
  chatId    String?
  expiresAt DateTime
  linkedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

// ─── Slack ────────────────────────────────────────────────────────────────────

model SlackWorkspace {
  id                 String    @id @default(cuid())
  userId             String
  teamId             String    @unique
  teamName           String?
  channelId          String?
  linkedAt           DateTime  @default(now())
  lastSeenAt         DateTime?
  lastConversationId String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model SlackPairing {
  id        String    @id @default(cuid())
  userId    String
  code      String    @unique
  command   String
  status    String    @default("pending") // pending | linked | expired | canceled
  teamId    String?
  expiresAt DateTime
  linkedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

// ─── Discord ──────────────────────────────────────────────────────────────────

model DiscordServer {
  id                 String    @id @default(cuid())
  userId             String
  guildId            String    @unique
  guildName          String?
  channelId          String?
  linkedAt           DateTime  @default(now())
  lastSeenAt         DateTime?
  lastConversationId String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model DiscordPairing {
  id        String    @id @default(cuid())
  userId    String
  code      String    @unique
  command   String
  status    String    @default("pending") // pending | linked | expired | canceled
  guildId   String?
  expiresAt DateTime
  linkedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

// ─── Webhooks ─────────────────────────────────────────────────────────────────

model Webhook {
  id        String   @id @default(cuid())
  userId    String
  url       String
  events    String   // JSON array string - WebhookEventType[]
  secret    String?
  enabled   Boolean  @default(true)
  headers   String?  // JSON string for custom headers
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@unique([userId, url])
  @@index([userId, enabled])
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  webhookId       String
  userId          String
  event           String   // WebhookEventType
  payload         String   // JSON string - WebhookPayload
  status          String   @default("pending") // pending | success | failed | retrying
  attempts        Int      @default(0)
  lastAttemptAt   DateTime?
  responseStatus  Int?
  responseBody    String?
  error           String?
  createdAt       DateTime @default(now())

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([webhookId, status])
  @@index([webhookId, createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
}

// ─── Metrics & Analytics ──────────────────────────────────────────────────────

model Trigger {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  event       String
  filter      String?  // JSON string
  actions     String   // JSON string
  workflowId  String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events TriggerEvent[]

  @@index([userId, createdAt])
  @@index([userId, event, enabled])
}

model TriggerEvent {
  id              String   @id @default(cuid())
  triggerId       String
  userId          String
  event           String
  payload         String   // JSON string
  status          String   @default("received") // received | processing | matched | not_matched | completed | failed
  matchedTrigger  String?
  actionsExecuted Int?
  error           String?
  createdAt       DateTime @default(now())
  processedAt     DateTime?

  trigger Trigger @relation(fields: [triggerId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([triggerId, createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model MetricLog {
  id              String   @id @default(cuid())
  userId          String
  metricType      String   // agent_run | tool_call | approval | conversation
  action          String   // started | completed | failed | approved | denied
  provider        String?  // anthropic | openai | google | minimax | ollama
  model           String?
  durationMs      Int?
  tokensUsed      Int?
  costUsd         Float?
  conversationId   String?
  toolName        String?
  metadata        String?  // JSON string
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, metricType, createdAt])
  @@index([userId, createdAt])
  @@index([metricType, createdAt])
}

model BudgetLimit {
  id            String   @id @default(cuid())
  userId        String
  budgetType    String   // daily | weekly | monthly | total
  limitUsd      Float
  alertAtUsd   Float?   // Send warning at this threshold
  currentSpentUsd Float  @default(0)
  periodStart   DateTime
  periodEnd     DateTime
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, budgetType])
  @@index([userId, periodStart])
}

// ─── Conversation Summarization ─────────────────────────────────────────────────

model ConversationSummary {
  id              String   @id @default(cuid())
  conversationId   String
  userId          String
  summary         String
  keyTopics       String   @default("[]") // JSON array
  type            String   @default("auto") // auto | manual
  summaryType     String   @default("full") // full | recent | delta
  tokensUsed      Int?
  model           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  highlights ConversationHighlight[]

  @@index([userId, conversationId])
  @@index([conversationId, createdAt])
}

model ConversationHighlight {
  id              String   @id @default(cuid())
  summaryId       String
  messageId       String
  userId          String
  type            String   // key_point | decision | question | insight | action
  content         String
  importance      String   @default("medium") // low | medium | high
  startIndex     Int?
  endIndex       Int?
  createdAt       DateTime @default(now())

  summary ConversationSummary @relation(fields: [summaryId], references: [id], onDelete: Cascade)
  user   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionItem ActionItem?

  @@index([userId, createdAt])
  @@index([summaryId, type])
}

model ActionItem {
  id              String   @id @default(cuid())
  userId          String
  highlightId     String?  @unique
  description     String
  assignee        String?
  dueDate         DateTime?
  status          String   @default("pending") // pending | completed | deferred
  sourceMessageId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  highlight ConversationHighlight? @relation(fields: [highlightId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([userId, dueDate])
}

model AgentPreset {
  id                 String   @id @default(cuid())
  userId             String
  workspaceId        String?
  name               String
  description        String?
  role               String   @default("assistant")
  outputStyle        String?
  autonomyMode       String   @default("assist")
  visibility         String   @default("private")
  version            Int      @default(1)
  preferredProvider  String?
  preferredModel     String?
  customSystemPrompt String?
  enabledSkills      String   @default("[]")
  tools              String   @default("[]")
  connectorIds       String   @default("[]")
  suggestedWorkflowIds String @default("[]")
  policyJson         String?
  appliedCount       Int      @default(0)
  lastAppliedAt      DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation("WorkspacePresets", fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
  @@index([workspaceId, updatedAt])
}

model Artifact {
  id                 String   @id @default(cuid())
  userId             String
  workspaceId        String?
  title              String
  type               String
  status             String   @default("draft")
  summary            String?
  labels             String   @default("[]")
  sourceConversationId String?
  sourceWorkflowId   String?
  sourcePresetId     String?
  sourcePackId       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace     Workspace?       @relation("WorkspaceOwnedArtifacts", fields: [workspaceId], references: [id], onDelete: SetNull)
  versions      ArtifactVersion[]
  sharedLinks   WorkspaceArtifact[]

  @@index([userId, updatedAt])
  @@index([workspaceId, updatedAt])
}

model ArtifactVersion {
  id         String   @id @default(cuid())
  artifactId String
  version    Int
  format     String   @default("markdown")
  content    String
  note       String?
  metadata   String?
  createdAt  DateTime @default(now())

  artifact Artifact @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([artifactId, version])
  @@index([artifactId, createdAt])
}

model ArtifactTemplate {
  id            String   @id @default(cuid())
  userId        String
  workspaceId   String?
  name          String
  description   String?
  type          String
  defaultFormat String   @default("markdown")
  outline       String?
  promptGuide   String?
  fieldSchema   String   @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation("WorkspaceArtifactTemplates", fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
  @@index([workspaceId, updatedAt])
}

model Workspace {
  id                         String   @id @default(cuid())
  ownerId                    String
  name                       String
  description                String?
  allowMemberInvites         Boolean  @default(true)
  requireApprovalForNewMembers Boolean @default(false)
  defaultMemberRole          String   @default("editor")
  sharedMemoryEnabled        Boolean  @default(true)
  sharedAgentsEnabled        Boolean  @default(true)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  owner            User                 @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members          WorkspaceMember[]
  invitations      WorkspaceInvitation[]
  conversations    WorkspaceConversation[]
  workflows        WorkspaceWorkflow[]
  sharedArtifacts  WorkspaceArtifact[]
  memoryEntries    WorkspaceMemoryEntry[]
  presets          AgentPreset[]        @relation("WorkspacePresets")
  artifacts        Artifact[]           @relation("WorkspaceOwnedArtifacts")
  artifactTemplates ArtifactTemplate[]  @relation("WorkspaceArtifactTemplates")
  packs            Pack[]               @relation("WorkspacePacks")

  @@index([ownerId, updatedAt])
}

model WorkspaceMember {
  id              String   @id @default(cuid())
  workspaceId     String
  userId          String
  role            String   @default("viewer")
  permissions     String   @default("[]")
  invitedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId, updatedAt])
}

model WorkspaceInvitation {
  id              String   @id @default(cuid())
  workspaceId     String
  email           String
  role            String   @default("viewer")
  invitedByUserId String
  status          String   @default("pending")
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([email, status])
}

model WorkspaceConversation {
  id             String   @id @default(cuid())
  workspaceId    String
  conversationId String
  title          String
  sharedByUserId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, conversationId])
  @@index([workspaceId, createdAt])
}

model WorkspaceWorkflow {
  id             String   @id @default(cuid())
  workspaceId    String
  workflowId     String
  name           String
  sharedByUserId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, workflowId])
  @@index([workspaceId, createdAt])
}

model WorkspaceArtifact {
  id             String   @id @default(cuid())
  workspaceId    String
  artifactId     String
  sharedByUserId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  artifact  Artifact  @relation(fields: [artifactId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, artifactId])
  @@index([workspaceId, createdAt])
}

model WorkspaceMemoryEntry {
  id              String   @id @default(cuid())
  workspaceId     String
  createdByUserId String
  type            String   @default("note")
  title           String
  content         String
  tags            String   @default("[]")
  sourceRef       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([workspaceId, updatedAt])
  @@index([createdByUserId, updatedAt])
}

model Pack {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String?
  slug        String
  name        String
  description String?
  version     String   @default("1.0.0")
  visibility  String   @default("private")
  tags        String   @default("[]")
  manifestJson String
  installCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace?  @relation("WorkspacePacks", fields: [workspaceId], references: [id], onDelete: SetNull)
  installs  PackInstall[]

  @@unique([userId, slug])
  @@index([visibility, updatedAt])
  @@index([workspaceId, updatedAt])
}

model AgentVersion {
  id             String   @id @default(cuid())
  userId         String
  agentId        String
  version        Int
  note           String?
  settings       Json
  runtimeConfig  Json
  skills         Json
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, agentId, version])
  @@unique([userId, agentId, version])
}

model PackInstall {
  id          String   @id @default(cuid())
  packId      String
  userId      String
  status      String   @default("installed")
  summary     String?
  createdAt   DateTime @default(now())

  pack Pack @relation(fields: [packId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([packId, userId])
  @@index([userId, createdAt])
}