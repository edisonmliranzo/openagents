# Bind web server (0.0.0.0 for LAN/external reachability)
WEB_HOST=0.0.0.0
WEB_PORT=3000
# Optional public override shown in docs and runtime logs.
# Browser API calls use the current web origin and proxy through Next.js.
NEXT_PUBLIC_API_URL=
# Optional internal proxy target used by the Next.js server.
# In dev, default is auto-derived from API_PORT.
OPENAGENTS_INTERNAL_API_URL=
# Optional override for Ollama base URL shown in Settings/Benchmark.
NEXT_PUBLIC_OLLAMA_BASE_URL=http://localhost:11434
# Optional: printed on startup as the external login URL.
# Example: https://agent.example.com/login
PUBLIC_LOGIN_URL=
# Alternative to PUBLIC_LOGIN_URL ("/login" will be appended).
PUBLIC_BASE_URL=
