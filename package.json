{
  "name": "openagents",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "setup:skip-docker": "node scripts/setup.mjs --skip-docker",
    "setup:skip-migrate": "node scripts/setup.mjs --skip-migrate",
    "ml:preprocess": "python ml/automation.py --config ml/config.yaml preprocess",
    "ml:hpo": "python ml/automation.py --config ml/config.yaml hpo",
    "ml:train": "python ml/automation.py --config ml/config.yaml train",
    "ml:pipeline": "python ml/automation.py --config ml/config.yaml pipeline",
    "ml:schedule": "python ml/automation.py --config ml/config.yaml schedule",
    "ml:calendar": "python ml/automation.py --config ml/config.yaml calendar-watch",
    "ml:api": "python ml/automation.py --config ml/config.yaml serve --host 0.0.0.0 --port 8010",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "doctor": "node scripts/doctor.mjs",
    "backup:create": "node scripts/backup.mjs create",
    "backup:restore": "node scripts/backup.mjs restore",
    "backup:list": "node scripts/backup.mjs list",
    "db:migrate": "pnpm --filter api run db:migrate",
    "db:studio": "pnpm --filter api run db:studio",
    "prod:build": "node scripts/prod-stack.mjs build",
    "prod:up": "node scripts/prod-stack.mjs up",
    "prod:deploy": "node scripts/prod-stack.mjs deploy",
    "prod:down": "node scripts/prod-stack.mjs down",
    "prod:logs": "node scripts/prod-stack.mjs logs",
    "prod:ps": "node scripts/prod-stack.mjs ps",
    "prod:check:ollama": "node scripts/check-ollama-health.mjs"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.2.0"
  }
}
